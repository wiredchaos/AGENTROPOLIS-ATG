{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentropolis.dev/schemas/nft-gateway/avatar-forge.schema.json",
  "title": "Avatar Forge Fabrication Mandate",
  "description": "Routes a verified or visually referenced NFT identity into the Construction District for non-custodial avatar fabrication.",
  "type": "object",
  "additionalProperties": false,
  "required": ["mandate_id", "identity_source", "fabrication", "routing", "authority", "receipt"],
  "properties": {
    "mandate_id": { "type": "string", "minLength": 8, "maxLength": 128 },
    "identity_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assurance_state", "asset_reference"],
      "properties": {
        "assurance_state": {
          "type": "string",
          "enum": ["IMAGE_ONLY", "ASSET_LOCATED", "COLLECTION_VERIFIED", "OWNERSHIP_OBSERVED", "CONTROL_VERIFIED", "ECONOMIC_RECHECK_PASSED"]
        },
        "asset_reference": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "collection_reference": { "type": ["string", "null"], "maxLength": 512 },
        "source_image_url": { "type": ["string", "null"], "format": "uri", "maxLength": 2048 }
      }
    },
    "fabrication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_type", "style_policy", "preserve_identity_traits"],
      "properties": {
        "output_type": { "type": "string", "enum": ["avatar_2d", "avatar_3d", "game_rig", "profile_render", "world_npc"] },
        "style_policy": { "type": "string", "enum": ["original_translation", "lore_safe_reskin", "collection_faithful", "user_directed"] },
        "preserve_identity_traits": { "type": "boolean", "const": true },
        "target_format": { "type": "string", "enum": ["png", "webp", "glb", "gltf", "fbx", "vrm"] },
        "lod": { "type": "string", "enum": ["preview", "game_ready", "cinematic"] },
        "notes": { "type": "string", "maxLength": 2000 }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin", "institution", "toolchain", "destination"],
      "properties": {
        "origin": { "const": "Gaming District" },
        "institution": { "const": "Construction District" },
        "toolchain": {
          "type": "array",
          "prefixItems": [
            { "const": "Creator MCP" },
            { "const": "Blender MCP" },
            { "const": "Asset Registry" }
          ],
          "minItems": 3,
          "maxItems": 3
        },
        "destination": { "type": "string", "enum": ["Distribution Layer", "Hermes City", "Game Runtime", "Profile Registry"] }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wallet_connected", "custody", "transfer_permission", "economic_action"],
      "properties": {
        "wallet_connected": { "const": false },
        "custody": { "const": false },
        "transfer_permission": { "const": false },
        "economic_action": { "const": false },
        "human_review_required": { "type": "boolean", "default": true }
      }
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "state"],
      "properties": {
        "required": { "const": true },
        "state": { "type": "string", "enum": ["PENDING", "FABRICATED", "VALIDATED", "REGISTERED", "REJECTED"] },
        "artifact_hash": { "type": ["string", "null"], "maxLength": 256 },
        "registry_id": { "type": ["string", "null"], "maxLength": 256 }
      }
    }
  }
}
