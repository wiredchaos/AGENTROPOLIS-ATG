{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentropolis.dev/schemas/nft-gateway/resolve-request.schema.json",
  "title": "NFT Gateway Resolve Request",
  "description": "Public, read-only NFT discovery input. This contract never accepts seed phrases, private keys, wallet approvals, delegate authority, or transaction signing permissions.",
  "type": "object",
  "additionalProperties": false,
  "required": ["request_id", "input"],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "wallet_address": { "type": "string", "minLength": 8, "maxLength": 256 },
        "asset_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "transaction_signature": { "type": "string", "minLength": 8, "maxLength": 256 },
        "marketplace_or_explorer_url": { "type": "string", "format": "uri", "maxLength": 2048 },
        "image_reference": { "type": "string", "format": "uri", "maxLength": 2048 },
        "chain_hint": {
          "type": "string",
          "enum": ["dogechain", "solchain", "ethereum", "base", "bitcoin", "polygon", "other"]
        }
      },
      "anyOf": [
        { "required": ["wallet_address"] },
        { "required": ["asset_id"] },
        { "required": ["transaction_signature"] },
        { "required": ["marketplace_or_explorer_url"] },
        { "required": ["image_reference"] }
      ]
    },
    "requested_assurance": {
      "type": "string",
      "enum": ["visual_reference", "asset_location", "collection_verification", "ownership_observation", "control_verification"],
      "default": "ownership_observation"
    },
    "purpose": {
      "type": "string",
      "enum": ["avatar_preview", "avatar_forge", "game_identity", "profile_claim", "economic_action"],
      "default": "avatar_preview"
    }
  }
}
