{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentropolis.dev/schemas/nft-gateway/resolve-response.schema.json",
  "title": "NFT Gateway Resolve Response",
  "description": "Read-only NFT resolution result with explicit assurance state and evidence. It grants no spending, transfer, approval, custody, or signing authority.",
  "type": "object",
  "additionalProperties": false,
  "required": ["request_id", "status", "assurance_state", "asset", "evidence", "authority"],
  "properties": {
    "request_id": { "type": "string", "minLength": 8, "maxLength": 128 },
    "status": { "type": "string", "enum": ["resolved", "partial", "unresolved", "rejected"] },
    "assurance_state": {
      "type": "string",
      "enum": ["IMAGE_ONLY", "ASSET_LOCATED", "COLLECTION_VERIFIED", "OWNERSHIP_OBSERVED", "CONTROL_VERIFIED", "ECONOMIC_RECHECK_PASSED"]
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chain", "asset_id"],
      "properties": {
        "chain": { "type": "string", "minLength": 2, "maxLength": 64 },
        "asset_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "collection_id": { "type": ["string", "null"], "maxLength": 256 },
        "collection_name": { "type": ["string", "null"], "maxLength": 256 },
        "owner_address_observed": { "type": ["string", "null"], "maxLength": 256 },
        "image_url": { "type": ["string", "null"], "format": "uri", "maxLength": 2048 },
        "metadata_url": { "type": ["string", "null"], "format": "uri", "maxLength": 2048 }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "source", "observed_at"],
        "properties": {
          "type": { "type": "string", "enum": ["explorer", "marketplace", "rpc", "indexer", "image_reference", "signed_message"] },
          "source": { "type": "string", "format": "uri", "maxLength": 2048 },
          "observed_at": { "type": "string", "format": "date-time" },
          "artifact_hash": { "type": ["string", "null"], "maxLength": 256 }
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "wallet_connected", "transaction_authority", "private_key_access"],
      "properties": {
        "mode": { "const": "read_only" },
        "wallet_connected": { "const": false },
        "transaction_authority": { "const": false },
        "private_key_access": { "const": false },
        "economic_action_allowed": { "type": "boolean", "default": false }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string", "maxLength": 512 },
      "default": []
    }
  }
}
